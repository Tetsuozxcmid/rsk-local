# Copy to .env in this directory (RSK_back/) and fill secrets. File .env is gitignored.
# Run from RSK_back/: docker compose -f docker-compose.local.yml up --build
# Docker Compose loads .env automatically from this folder for ${VAR} substitution and service env_file.

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change_me_rabbit
RABBITMQ_URL=amqp://admin:change_me_rabbit@rabbitmq:5672/

# --- Postgres (per database) ---
DB_AUTH_USER=postgres
DB_AUTH_PASSWORD=postgres
DB_AUTH_NAME=rsk_back

DB_PROFILE_USER=postgres
DB_PROFILE_PASSWORD=postgres
DB_PROFILE_NAME=rsk_profile

DB_TEAMS_USER=postgres
DB_TEAMS_PASSWORD=postgres
DB_TEAMS_NAME=rsk_teams

DB_ORGS_USER=postgres
DB_ORGS_PASSWORD=postgres
DB_ORGS_NAME=rsk_organizations

DB_PROJECTS_USER=postgres
DB_PROJECTS_PASSWORD=postgres
DB_PROJECTS_NAME=rsk_projects

DB_LEARNING_USER=postgres
DB_LEARNING_PASSWORD=postgres
DB_LEARNING_NAME=rsk_learning

# --- Shared JWT ---
SECRET_KEY=change_me_to_a_long_random_string
ALGORITHM=HS256

# --- Auth: SMTP ---
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_PORT=1025
SMTP_SERVER=mailhog
SENDER_EMAIL=noreply@local.test

AUTH_SERVICE_URL=http://rsk_auth_app:8002
URL_FOR_TOKEN=http://localhost:8002

FRONTEND_URL=http://localhost:3000/profile
YANDEX_FRONTEND_URL=http://localhost:3000/profile

VK_APP_ID=0
VK_APP_SECRET=change_me
VK_REDIRECT_URI=http://localhost:8002/users_interaction/auth/vk/callback

YANDEX_CLIENT_ID=change_me
YANDEX_CLIENT_SECRET=change_me
YANDEX_REDIRECT_URI=http://localhost:8002/users_interaction/auth/yandex/callback

# --- user_profile ---
ORGS_URL=http://rsk_orgs_app:8005

# --- teams ---
RSK_BOT_URL=http://admin_bot:8009

# --- orgs ---
USERS_SERVICE_URL=http://rsk_profile_app:8003
TEAMS_SERVICE_URL=http://rsk_teams_app:8004/teams
DADATA_TOKEN=
DADATA_SECRET=

# --- learning ---
PROFILE_SERVICE_URL=http://rsk_profile_app:8003
REDIS_URL=redis://redis:6379

# --- admin_service ---
BOT_TOKEN=change_me_telegram_bot_token
RSK_ORGS_URL=http://rsk_orgs_app:8005

# --- Next.js ---
NEXT_PUBLIC_API_ROUTING=direct
NEXT_PUBLIC_BASE_URL=http://localhost:3000
BACKEND_API_ROUTING=direct

# --- Auth cookies: empty COOKIE_DOMAIN = host-only (local). Production: COOKIE_DOMAIN=.rosdk.ru COOKIE_SECURE=true ---
COOKIE_DOMAIN=
COOKIE_SECURE=false

# --- Next.js /api/auth/logout ---
LOGOUT_COOKIE_DOMAIN=
LOGOUT_COOKIE_SECURE=false

# --- Optional CORS (comma-separated) ---
CORS_EXTRA_ORIGINS=
