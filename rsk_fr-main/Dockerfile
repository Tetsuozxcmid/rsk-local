FROM node:20-alpine

WORKDIR /app

ARG NEXT_PUBLIC_API_ROUTING=
ARG NEXT_PUBLIC_BASE_URL=http://localhost:3000
ENV NEXT_PUBLIC_API_ROUTING=$NEXT_PUBLIC_API_ROUTING
ENV NEXT_PUBLIC_BASE_URL=$NEXT_PUBLIC_BASE_URL

COPY . .

RUN npm install
RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start", "--", "-p", "3000"]
